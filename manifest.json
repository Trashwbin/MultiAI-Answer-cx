{
  "manifest_version": 3,
  "name": "MultiAI Answer",
  "description": "基于多模型 AI 投票的智能答题助手，让答题更轻松、更准确。支持多个主流 AI 模型，智能分析题目，自动生成答案。",
  "version": "2.0.0",
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "author": "Trashwbin",
  "permissions": [
    "tabs",
    "clipboardRead",
    "clipboardWrite",
    "storage",
    "system.display",
    "cookies",
    "webRequest",
    "scripting"
  ],
  "host_permissions": [
    "https://*.chaoxing.com/*",
    "https://chat.deepseek.com/*",
    "https://kimi.com/*",
    "https://www.kimi.com/*",
    "https://kimi.moonshot.cn/*",
    "https://tongyi.aliyun.com/*",
    "https://chatglm.cn/*",
    "https://doubao.com/*",
    "https://www.doubao.com/*",
    "https://yiyan.baidu.com/*",
    "https://xinghuo.xfyun.cn/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://grok.com/*",
    "https://chat.qwen.ai/*",
    "http://127.0.0.1:*/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.chaoxing.com/*/work*",
        "https://*.chaoxing.com/*/mooc2/work*",
        "https://*.chaoxing.com/*/exam*",
        "https://*.chaoxing.com/*/mooc2/exam*",
        "https://*.chaoxing.com/*/test*",
        "https://*.chaoxing.com/*/mooc2/test*",
        "https://*.chaoxing.com/mycourse/studentstudy*",
        "http://127.0.0.1:*/*",
        "http://localhost:*/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://kimi.com/*",
        "https://www.kimi.com/*",
        "https://kimi.moonshot.cn/*",
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://www.doubao.com/*",
        "https://grok.com/*",
        "https://chat.qwen.ai/*",
        "https://chatglm.cn/*"
      ],
      "js": ["dist/auth-content.js"],
      "run_at": "document_end"
    }
  ]
}
